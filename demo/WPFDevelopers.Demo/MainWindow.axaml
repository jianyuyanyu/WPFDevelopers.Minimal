<Window
    x:Class="WPFDevelopers.Demo.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WPFDevelopers.Demo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers.Avalonia"
    Title="WPFDevelopers Demo"
    Width="800"
    Height="600"
    d:DesignHeight="600"
    d:DesignWidth="800"
    Icon="avares://WPFDevelopers.Demo/Assets/WPFDevelopers.ico"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    
    <ScrollViewer Margin="2">
        <StackPanel Spacing="20">

            <Image
                Width="120"
                Height="120"
                Margin="0,5"
                Source="avares://WPFDevelopers.Demo/Assets/WPFDevelopers.ico" />

            <!--  Title  -->
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="24"
                FontWeight="Bold"
                Text="WPFDevelopers.Avalonia Demo" />

            <ItemsControl x:Name="ColorItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" ItemSpacing="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="local:ColorOption">
                        <RadioButton
                            Width="25"
                            Height="25"
                            Margin="1"
                            CornerRadius="30"
                            GroupName="ColorGroup"
                            IsCheckedChanged="OnColorRadioButtonChecked"
                            Tag="{Binding}">
                            <RadioButton.Template>
                                <ControlTemplate>
                                    <Border
                                        Name="border"
                                        Background="{Binding Color}"
                                        BorderBrush="{DynamicResource WD.BaseBrush}"
                                        BorderThickness="2"
                                        CornerRadius="{TemplateBinding CornerRadius}">
                                        <PathIcon
                                            Width="14"
                                            Height="14"
                                            Data="M9 20.42l-6.21-6.21 2.83-2.83L9 14.77l9.88-9.88 2.83 2.83z"
                                            Foreground="White"
                                            IsVisible="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </Border>
                                </ControlTemplate>
                            </RadioButton.Template>
                            <ToolTip.Tip>
                                <TextBlock Text="{Binding Name}" />
                            </ToolTip.Tip>
                        </RadioButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Theme Toggle  -->
            <StackPanel
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="10">
                <TextBlock VerticalAlignment="Center" Text="Theme:" />
                <Button
                    Name="ThemeToggle"
                    Content="Switch to Dark"
                    Theme="{StaticResource wd-primary}" />
            </StackPanel>

            <!--  Buttons Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Buttons" />
                    <WrapPanel>
                        <Button
                            Margin="4"
                            Content="Primary"
                            Theme="{StaticResource wd-primary}" />
                        <Button
                            Width="40"
                            Height="40"
                            Margin="4"
                            wd:ElementHelper.IsRound="True"
                            Content="Round"
                            Theme="{StaticResource wd-primary}" />
                        <Button
                            Margin="4"
                            Content="Default"
                            Theme="{StaticResource wd-default}" />
                        <Button
                            Margin="4"
                            Content="Normal"
                            Theme="{StaticResource wd-normal}" />
                        <Button
                            Margin="4"
                            wd:Loading.IsShow="True"
                            Content="Success"
                            Theme="{StaticResource wd-success}" />
                        <Button
                            Margin="4"
                            Content="Warning"
                            Theme="{StaticResource wd-warning}" />
                        <Button
                            Margin="4"
                            Content="Danger"
                            Theme="{StaticResource wd-danger}" />
                        <Button
                            Margin="4"
                            Content="Filled Success"
                            Theme="{StaticResource wd-success-filled}" />
                        <Button
                            Margin="4"
                            Content="Filled Warning"
                            Theme="{StaticResource wd-warning-filled}" />
                        <Button
                            Margin="4"
                            Content="Filled Danger"
                            Theme="{StaticResource wd-danger-filled}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--  PathIcon Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Icons" />
                    <WrapPanel>
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.PrimaryBrush}"
                            Kind="Home" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.SuccessBrush}"
                            Kind="CheckMark" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.WarningBrush}"
                            Kind="Warning" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.DangerBrush}"
                            Kind="Error" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.PrimaryBrush}"
                            Kind="Info" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.WarningBrush}"
                            Kind="Star" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.PrimaryBrush}"
                            Kind="Add" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.RegularTextBrush}"
                            Kind="Time" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.RegularTextBrush}"
                            Kind="DatePicker" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.RegularTextBrush}"
                            Kind="Copy" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.RegularTextBrush}"
                            Kind="Undo" />
                        <wd:PathIconEx
                            Width="24"
                            Height="24"
                            Margin="4"
                            Foreground="{DynamicResource WD.RegularTextBrush}"
                            Kind="Filter" />
                        <PathIcon
                            Width="24"
                            Height="24"
                            Margin="4"
                            Data="{StaticResource WD.CheckMarkGeometry}"
                            Foreground="{DynamicResource WD.SuccessBrush}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--  Inputs Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Inputs" />
                    <TextBox
                        Width="200"
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        Text=""
                        Watermark="Enter text here..." />
                    <TextBox
                        Width="200"
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        Classes="IsClear"
                        Text=""
                        Watermark="Clear text" />
                    <TextBox
                        Width="200"
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        PasswordChar="●"
                        RevealPassword="False"
                        Watermark="Enter password here..." />
                    <TextBox
                        Width="200"
                        MaxWidth="400"
                        HorizontalAlignment="Left"
                        Classes="IsClear"
                        PasswordChar="●"
                        RevealPassword="False"
                        Watermark="Clear password" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox Content="CheckBox (checked)" IsChecked="True" />
                        <CheckBox Content="CheckBox (unchecked)" />
                        <CheckBox
                            Content="CheckBox (indeterminate)"
                            IsChecked="{x:Null}"
                            IsThreeState="True" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <RadioButton
                            Content="Option A"
                            GroupName="demo"
                            IsChecked="True" />
                        <RadioButton Content="Option B" GroupName="demo" />
                        <RadioButton Content="Option C" GroupName="demo" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <ToggleButton Content="Toggle Off" />
                        <ToggleButton Content="Toggle On" IsChecked="True" />
                        <ToggleButton IsChecked="True" Theme="{StaticResource wd-switch}" />
                        <ToggleButton Theme="{StaticResource wd-switch}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Tag Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Tags" />
                    <WrapPanel>
                        <wd:Tag
                            Margin="4"
                            Close="Tag_Close"
                            Content="Default Tag" />
                        <wd:Tag
                            Margin="4"
                            Content="Non-closable"
                            IsClose="False" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--  Mask Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Mask" />
                    <StackPanel Orientation="Horizontal" Spacing="32">
                        <Label
                            Width="100"
                            Height="100"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            wd:Mask.IsShow="True"
                            Background="{StaticResource WD.DangerBrush}"
                            Content="Lable Mask" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Loading Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Loading" />
                    <StackPanel Orientation="Horizontal" Spacing="32">
                        <Label
                            Width="100"
                            Height="100"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            wd:Loading.IsShow="True"
                            Background="{StaticResource WD.PrimaryBrush}"
                            Content="Lable Loading" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Badge Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Badge" />
                    <WrapPanel>
                        <Button
                            Margin="16"
                            wd:Badge.BadgeText="5"
                            Content="Messages"
                            Theme="{StaticResource wd-default}" />
                        <Button
                            Margin="16"
                            wd:Badge.BadgeText="99+"
                            Content="Notifications"
                            Theme="{StaticResource wd-default}" />
                        <Button
                            Margin="16"
                            wd:Badge.IsDot="True"
                            Content="Dot Badge"
                            Theme="{StaticResource wd-default}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--  Progress Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="4">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="Progress &amp; Slider" />
                        <ProgressBar
                            Width="400"
                            HorizontalAlignment="Left"
                            ShowProgressText="True"
                            Value="60" />
                        <ProgressBar
                            Width="400"
                            HorizontalAlignment="Left"
                            IsIndeterminate="True"
                            Value="20" />
                        <Slider
                            Width="400"
                            HorizontalAlignment="Left"
                            Maximum="100"
                            Minimum="0"
                            Value="40" />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="12">
                        <ProgressBar
                            Height="300"
                            HorizontalAlignment="Left"
                            Orientation="Vertical"
                            ShowProgressText="True"
                            Value="20" />
                        <ProgressBar
                            Height="300"
                            HorizontalAlignment="Left"
                            IsIndeterminate="True"
                            Orientation="Vertical"
                            Value="20" />
                        <Slider
                            Width="400"
                            HorizontalAlignment="Left"
                            Maximum="100"
                            Minimum="0"
                            Orientation="Vertical"
                            Value="40" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Expander Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Expander" />
                    <UniformGrid
                        Margin="0,10"
                        ColumnSpacing="5"
                        Columns="2"
                        RowSpacing="5">
                        <Expander Header="Expander">
                            <Rectangle
                                Width="400"
                                Height="300"
                                Fill="{DynamicResource WD.DangerBrush}" />
                        </Expander>
                        <Expander
                            ExpandDirection="Up"
                            FlowDirection="RightToLeft"
                            Header="Expander1"
                            IsExpanded="True">
                            <Rectangle
                                Width="400"
                                Height="300"
                                Fill="{DynamicResource WD.LightBrush}" />
                        </Expander>
                        <Expander ExpandDirection="Right" Header="Expander">
                            <Rectangle
                                Width="400"
                                Height="300"
                                Fill="{DynamicResource WD.SuccessMouseOverBrush}" />
                        </Expander>
                        <Expander
                            ExpandDirection="Left"
                            Header="Expander"
                            IsExpanded="True">
                            <Rectangle
                                Width="400"
                                Height="300"
                                Fill="{DynamicResource WD.PrimaryBrush}" />
                        </Expander>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!--  ComboBox Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="ComboBox" />
                    <ComboBox
                        Width="200"
                        HorizontalAlignment="Left"
                        SelectedIndex="0">
                        <ComboBoxItem Content="Option 1" />
                        <ComboBoxItem Content="Option 2" />
                        <ComboBoxItem Content="Option 3" />
                        <ComboBoxItem Content="Option 4" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!--  DataGrid Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="DataGrid" />
                    <DataGrid
                        Name="DemoDataGrid"
                        Width="500"
                        Height="200"
                        HorizontalAlignment="Left"
                        x:DataType="local:DemoItem">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="150"
                                Binding="{Binding Name}"
                                Header="Name" />
                            <DataGridTextColumn
                                Width="80"
                                Binding="{Binding Age}"
                                Header="Age" />
                            <DataGridCheckBoxColumn
                                Width="80"
                                Binding="{Binding IsActive}"
                                Header="Active" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Role}"
                                Header="Role" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!--  Date & Time Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Date &amp; Time" />
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <DatePicker Width="200" HorizontalAlignment="Left" />
                            <Calendar />
                            <CalendarDatePicker Width="200" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TimePicker Width="200" HorizontalAlignment="Left" />
                            <TimePicker
                                Width="200"
                                HorizontalAlignment="Left"
                                UseSeconds="True" />
                            <TimePicker
                                Width="200"
                                HorizontalAlignment="Left"
                                ClockIdentifier="12HourClock" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  ListBox Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="ListBox" />
                    <ListBox
                        Width="200"
                        Height="150"
                        HorizontalAlignment="Left"
                        SelectionMode="Single">
                        <ListBoxItem Content="Item One" />
                        <ListBoxItem Content="Item Two" IsSelected="True" />
                        <ListBoxItem Content="Item Three" />
                        <ListBoxItem Content="Item Four" />
                        <ListBoxItem Content="Item Five" />
                        <ListBoxItem Content="Item Six" />
                    </ListBox>
                </StackPanel>
            </Border>

            <!--  Menu Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Menu" />
                    <Menu>
                        <MenuItem Header="File">
                            <MenuItem Header="New" />
                            <MenuItem Header="Open" />
                            <MenuItem Header="Save" />
                            <Separator />
                            <MenuItem Header="Exit" />
                        </MenuItem>
                        <MenuItem Header="Edit">
                            <MenuItem Header="Cut" />
                            <MenuItem Header="Copy" />
                            <MenuItem Header="Paste" />
                        </MenuItem>
                        <MenuItem Header="Help">
                            <MenuItem Header="About" />
                        </MenuItem>
                    </Menu>
                </StackPanel>
            </Border>

            <!--  TabControl Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="TabControl" />
                    <TabControl
                        Width="400"
                        Height="150"
                        HorizontalAlignment="Left">
                        <TabItem Header="General">
                            <TextBlock Margin="8" Text="General settings content" />
                        </TabItem>
                        <TabItem Header="Advanced">
                            <TextBlock Margin="8" Text="Advanced settings content" />
                        </TabItem>
                        <TabItem Header="About">
                            <TextBlock Margin="8" Text="About this application" />
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </Border>

            <!--  TreeView Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="TreeView" />
                    <TreeView
                        Width="250"
                        Height="200"
                        HorizontalAlignment="Left">
                        <TreeViewItem Header="Root">
                            <TreeViewItem Header="Child 1">
                                <TreeViewItem Header="Grandchild 1.1" />
                                <TreeViewItem Header="Grandchild 1.2" />
                            </TreeViewItem>
                            <TreeViewItem Header="Child 2" />
                            <TreeViewItem Header="Child 3" IsExpanded="True">
                                <TreeViewItem Header="Grandchild 3.1" />
                                <TreeViewItem Header="Grandchild 3.2" />
                            </TreeViewItem>
                        </TreeViewItem>
                    </TreeView>
                </StackPanel>
            </Border>

            <!--  GroupBox Section  -->
            <StackPanel Spacing="12">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="GroupBox" />
                <wd:GroupBox
                    Width="500"
                    HorizontalAlignment="Left"
                    Header="Group Title">
                    <TextBlock Margin="4" Text="This is the content of the GroupBox." />
                </wd:GroupBox>
            </StackPanel>

            <!--  RepeatButton Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="RepeatButton" />
                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <RepeatButton
                            Name="RepeatDecrementBtn"
                            Width="40"
                            Height="40"
                            Content="-"
                            FontSize="18" />
                        <TextBlock
                            Name="RepeatValueText"
                            Width="40"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Text="0"
                            TextAlignment="Center" />
                        <RepeatButton
                            Name="RepeatIncrementBtn"
                            Width="40"
                            Height="40"
                            FontSize="18">
                            <wd:PathIconEx Kind="Add" />
                        </RepeatButton>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Label & Separator Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Label &amp; Separator" />
                    <StackPanel>
                        <Label Content="Primary Label" Foreground="{DynamicResource WD.PrimaryBrush}" />
                        <Label Content="Regular label" />
                        <Label Margin="0,8,0,0" Content="HyperlinkButton">
                            <Label.ContentTemplate>
                                <DataTemplate>
                                    <HyperlinkButton Content="{Binding}" NavigateUri="https://github.com/WPFDevelopersOrg/WPFDevelopers.Avalonia" />
                                </DataTemplate>
                            </Label.ContentTemplate>
                        </Label>
                        <Separator Margin="0,12" />
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="16">
                            <Label Content="Inline label" />
                            <Border
                                Width="1"
                                Height="16"
                                Background="{DynamicResource WD.BaseBrush}" />
                            <Label Content="After separator" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  NumericUpDown Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="NumericUpDown" />
                    <StackPanel Spacing="4">
                        <Label Content="NumericUpDown" />
                        <NumericUpDown
                            Width="200"
                            HorizontalAlignment="Left"
                            Maximum="1000"
                            Minimum="0"
                            Value="42" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  AutoCompleteBox Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="AutoCompleteBox" />
                    <AutoCompleteBox
                        x:Name="DemoAutoCompleteBox"
                        Width="200"
                        HorizontalAlignment="Left"
                        FilterMode="Contains"
                        Watermark="Search..." />
                </StackPanel>
            </Border>

            <!--  SplitView Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="SplitView" />
                    <StackPanel
                        Margin="0,0,0,8"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            Name="SplitViewToggleBtn"
                            Content="Toggle Pane"
                            Theme="{StaticResource wd-primary}" />
                        <RadioButton
                            Name="SplitViewCompactBtn"
                            Content="Compact"
                            GroupName="SplitViewMode"
                            IsChecked="True" />
                        <RadioButton
                            Name="SplitViewOverlayBtn"
                            Content="Overlay"
                            GroupName="SplitViewMode" />
                        <RadioButton
                            Name="SplitViewInlineBtn"
                            Content="Inline"
                            GroupName="SplitViewMode" />
                    </StackPanel>
                    <SplitView
                        x:Name="DemoSplitView"
                        Width="400"
                        Height="250"
                        HorizontalAlignment="Left"
                        DisplayMode="CompactOverlay"
                        IsPaneOpen="True"
                        OpenPaneLength="200">
                        <SplitView.Pane>
                            <StackPanel Background="{DynamicResource WD.BaseMoveBrush}">
                                <TextBlock
                                    Margin="8,0"
                                    FontWeight="SemiBold"
                                    Text="Pane" />
                                <Button
                                    Margin="0,2"
                                    Content="Home"
                                    Theme="{StaticResource wd-normal}" />
                                <Button
                                    Margin="0,2"
                                    Content="Settings"
                                    Theme="{StaticResource wd-normal}" />
                                <Button
                                    Margin="0,2"
                                    Content="About"
                                    Theme="{StaticResource wd-normal}" />
                            </StackPanel>
                        </SplitView.Pane>
                        <Border Padding="16" Background="{DynamicResource WD.LightBrush}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="Main Content" />
                        </Border>
                    </SplitView>
                </StackPanel>
            </Border>

            <!--  ContextMenu Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="ContextMenu" />
                    <Button
                        Width="250"
                        HorizontalAlignment="Left"
                        Content="Right-click me for ContextMenu"
                        Theme="{StaticResource wd-default}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy" />
                                <MenuItem Header="Paste" />
                                <MenuItem Header="Cut" />
                                <Separator />
                                <MenuItem Header="Select All" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource WD.RegularTextBrush}"
                        Text="Right-click any control to see its ContextMenu" />
                </StackPanel>
            </Border>

            <!--  Toast Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Toast" />
                    <WrapPanel>
                        <Button
                            Name="ToastInfoBtn"
                            Margin="4"
                            Content="Info"
                            Theme="{StaticResource wd-primary}" />
                        <Button
                            Name="ToastSuccessBtn"
                            Margin="4"
                            Content="Success"
                            Theme="{StaticResource wd-success}" />
                        <Button
                            Name="ToastWarningBtn"
                            Margin="4"
                            Content="Warning"
                            Theme="{StaticResource wd-warning}" />
                        <Button
                            Name="ToastErrorBtn"
                            Margin="4"
                            Content="Error"
                            Theme="{StaticResource wd-danger}" />
                        <Button
                            Name="ToastClearBtn"
                            Margin="4"
                            Content="Clear"
                            Theme="{StaticResource wd-normal}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--  MessageBox Section  -->
            <Border
                Padding="16"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="MessageBox" />
                    <WrapPanel>
                        <Button
                            Name="MsgBoxInfoBtn"
                            Margin="4"
                            Content="Info"
                            Theme="{StaticResource wd-primary}" />
                        <Button
                            Name="MsgBoxWarningBtn"
                            Margin="4"
                            Content="Warning"
                            Theme="{StaticResource wd-warning}" />
                        <Button
                            Name="MsgBoxErrorBtn"
                            Margin="4"
                            Content="Error"
                            Theme="{StaticResource wd-danger}" />
                        <Button
                            Name="MsgBoxQuestionBtn"
                            Margin="4"
                            Content="Question"
                            Theme="{StaticResource wd-success}" />
                        <Button
                            Name="MsgBoxYesNoCancelBtn"
                            Margin="4"
                            Content="YesNoCancel"
                            Theme="{StaticResource wd-default}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
