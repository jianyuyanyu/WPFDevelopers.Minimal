<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="https://github.com/WPFDevelopersOrg/WPFDevelopers.Avalonia"
        xmlns:local="using:WPFDevelopers.Demo"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="WPFDevelopers.Demo.MainWindow"
        Icon="avares://WPFDevelopers.Demo/Assets/WPFDevelopers.ico"
        WindowStartupLocation="CenterScreen"
        Title="WPFDevelopers Demo"
        Width="800" Height="600">
    <ScrollViewer Margin="2">
        <StackPanel Spacing="20">

            <Image Source="avares://WPFDevelopers.Demo/Assets/WPFDevelopers.ico" Width="120" Height="120" Margin="0,5"/>

            <!--Title-->
            <TextBlock Text="WPFDevelopers.Avalonia Demo"
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" />

            <ItemsControl x:Name="ColorItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" ItemSpacing="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="local:ColorOption">
                        <RadioButton Width="25" Height="25"
                                     Margin="1"
                                     CornerRadius="30"
                                     GroupName="ColorGroup"
                                     Tag="{Binding}"
                                     IsCheckedChanged="OnColorRadioButtonChecked">
                            <RadioButton.Template>
                                <ControlTemplate>
                                    <Border Name="border"
                                            Background="{Binding Color}"
                                            BorderBrush="{DynamicResource WD.BaseBrush}"
                                            BorderThickness="2"
                                            CornerRadius="{TemplateBinding CornerRadius}">
                                        <PathIcon Data="M9 20.42l-6.21-6.21 2.83-2.83L9 14.77l9.88-9.88 2.83 2.83z"
                                                  Width="14" Height="14"
                                                  Foreground="White"
                                                  IsVisible="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </Border>
                                </ControlTemplate>
                            </RadioButton.Template>
                            <ToolTip.Tip>
                                <TextBlock Text="{Binding Name}"/>
                            </ToolTip.Tip>
                        </RadioButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--Theme Toggle-->
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <TextBlock Text="Theme:" VerticalAlignment="Center" />
                <Button Name="ThemeToggle" Content="Switch to Dark" Theme="{StaticResource wd-primary}" />
            </StackPanel>

            <!--Buttons Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Buttons" FontSize="18" FontWeight="SemiBold" />
                    <WrapPanel>
                        <Button Content="Primary" Theme="{StaticResource wd-primary}" Margin="4"/>
                        <Button Content="Default" Theme="{StaticResource wd-default}" Margin="4" />
                        <Button Content="Normal" Theme="{StaticResource wd-normal}" Margin="4" />
                        <Button Content="Success" Theme="{StaticResource wd-success}" Margin="4" controls:Loading.IsShow="True" />
                        <Button Content="Warning" Theme="{StaticResource wd-warning}" Margin="4" />
                        <Button Content="Danger" Theme="{StaticResource wd-danger}" Margin="4" />
                        <Button Content="Filled Success" Theme="{StaticResource wd-success-filled}" Margin="4" />
                        <Button Content="Filled Warning" Theme="{StaticResource wd-warning-filled}" Margin="4" />
                        <Button Content="Filled Danger" Theme="{StaticResource wd-danger-filled}" Margin="4" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--PathIcon Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Icons" FontSize="18" FontWeight="SemiBold" />
                    <WrapPanel>
                        <controls:PathIconEx Kind="Home" Width="24" Height="24" Foreground="{DynamicResource WD.PrimaryBrush}" Margin="4" />
                        <controls:PathIconEx Kind="CheckMark" Width="24" Height="24" Foreground="{DynamicResource WD.SuccessBrush}" Margin="4" />
                        <controls:PathIconEx Kind="Warning" Width="24" Height="24" Foreground="{DynamicResource WD.WarningBrush}" Margin="4" />
                        <controls:PathIconEx Kind="Error" Width="24" Height="24" Foreground="{DynamicResource WD.DangerBrush}" Margin="4" />
                        <controls:PathIconEx Kind="Info" Width="24" Height="24" Foreground="{DynamicResource WD.PrimaryBrush}" Margin="4" />
                        <controls:PathIconEx Kind="Star" Width="24" Height="24" Foreground="{DynamicResource WD.WarningBrush}" Margin="4" />
                        <controls:PathIconEx Kind="Add" Width="24" Height="24" Foreground="{DynamicResource WD.PrimaryBrush}" Margin="4" />
                        <controls:PathIconEx Kind="Time" Width="24" Height="24" Foreground="{DynamicResource WD.RegularTextBrush}" Margin="4" />
                        <controls:PathIconEx Kind="DatePicker" Width="24" Height="24" Foreground="{DynamicResource WD.RegularTextBrush}" Margin="4" />
                        <controls:PathIconEx Kind="Copy" Width="24" Height="24" Foreground="{DynamicResource WD.RegularTextBrush}" Margin="4" />
                        <controls:PathIconEx Kind="Undo" Width="24" Height="24" Foreground="{DynamicResource WD.RegularTextBrush}" Margin="4" />
                        <controls:PathIconEx Kind="Filter" Width="24" Height="24" Foreground="{DynamicResource WD.RegularTextBrush}" Margin="4" />
                        <PathIcon Data="{StaticResource WD.CheckMarkGeometry}" Foreground="{DynamicResource WD.SuccessBrush}" Width="24" Height="24" Margin="4" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--Inputs Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Inputs" FontSize="18" FontWeight="SemiBold" />
                    <TextBox Text="" Watermark="Enter text here..." Width="200" MaxWidth="400" HorizontalAlignment="Left" />
                    <TextBox Text="" Watermark="Clear text" Classes="IsClear" Width="200" MaxWidth="400" HorizontalAlignment="Left" />
                    <TextBox Watermark="Enter password here..." PasswordChar="●" RevealPassword="False" Width="200" MaxWidth="400" HorizontalAlignment="Left"/>
                    <TextBox Watermark="Clear password" PasswordChar="●" Classes="IsClear" RevealPassword="False" Width="200" MaxWidth="400" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox Content="CheckBox (checked)" IsChecked="True" />
                        <CheckBox Content="CheckBox (unchecked)" />
                        <CheckBox Content="CheckBox (indeterminate)" IsThreeState="True" IsChecked="{x:Null}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <RadioButton Content="Option A" GroupName="demo" IsChecked="True" />
                        <RadioButton Content="Option B" GroupName="demo" />
                        <RadioButton Content="Option C" GroupName="demo" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <ToggleButton Content="Toggle Off" />
                        <ToggleButton Content="Toggle On" IsChecked="True" />
                        <ToggleButton Classes="wd-switch" IsChecked="True" />
                        <ToggleButton Classes="wd-switch" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--Tag Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Tags" FontSize="18" FontWeight="SemiBold" />
                    <WrapPanel>
                        <controls:Tag Content="Default Tag" Margin="4" Close="Tag_Close" />
                        <controls:Tag Content="Non-closable" IsClose="False" Margin="4" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--Mask Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Mask" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="32">
                        <Label Content="Lable Mask" VerticalContentAlignment="Center"
                               HorizontalContentAlignment="Center"
                               Background="{StaticResource WD.DangerBrush}"
                               Width="100" Height="100"
                               controls:Mask.IsShow="True"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--Loading Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Loading" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="32">
                        <Label Content="Lable Loading" VerticalContentAlignment="Center"
                               HorizontalContentAlignment="Center"
                               Background="{StaticResource WD.PrimaryBrush}"
                               Width="100" Height="100"
                               controls:Loading.IsShow="True"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--Badge Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Badge" FontSize="18" FontWeight="SemiBold" />
                    <WrapPanel>
                        <Button controls:Badge.BadgeText="5" Content="Messages" Theme="{StaticResource wd-default}" Margin="16" />
                        <Button controls:Badge.BadgeText="99+" Content="Notifications" Theme="{StaticResource wd-default}" Margin="16" />
                        <Button controls:Badge.IsDot="True" Content="Dot Badge" Theme="{StaticResource wd-default}" Margin="16" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!--Progress Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="4">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Progress &amp; Slider" FontSize="18" FontWeight="SemiBold" />
                        <ProgressBar Value="60" Width="400" HorizontalAlignment="Left" ShowProgressText="True"/>
                        <ProgressBar IsIndeterminate="True" Value="20" Width="400" HorizontalAlignment="Left" />
                        <Slider Width="400" HorizontalAlignment="Left" Minimum="0" Maximum="100" Value="40" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="12" Orientation="Horizontal">
                        <ProgressBar Value="20" Height="300" Orientation="Vertical" HorizontalAlignment="Left" ShowProgressText="True"/>
                        <ProgressBar IsIndeterminate="True" Value="20" Height="300" Orientation="Vertical" HorizontalAlignment="Left" />
                        <Slider Width="400" Orientation="Vertical" HorizontalAlignment="Left" Minimum="0" Maximum="100" Value="40" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--Expander Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Expander" FontSize="18" FontWeight="SemiBold" />
                    <UniformGrid Margin="0,10" Columns="2" ColumnSpacing="5" RowSpacing="5">
                        <Expander Header="Expander">
                            <Rectangle
                            Width="400"
                            Height="300"
                            Fill="{DynamicResource WD.DangerBrush}" />
                        </Expander>
                        <Expander
                        ExpandDirection="Up"
                        FlowDirection="RightToLeft"
                        Header="Expander1"
                        IsExpanded="True">
                            <Rectangle Width="400"
                                       Height="300"
                                       Fill="{DynamicResource WD.LightBrush}" />
                        </Expander>
                        <Expander ExpandDirection="Right" Header="Expander">
                            <Rectangle
                            Width="400"
                            Height="300"
                            Fill="{DynamicResource WD.SuccessMouseOverBrush}" />
                        </Expander>
                        <Expander
                        ExpandDirection="Left"
                        IsExpanded="True" Header="Expander">
                            <Rectangle
                            Width="400"
                            Height="300"
                            Fill="{DynamicResource WD.PrimaryBrush}" />
                        </Expander>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!--ComboBox Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="ComboBox" FontSize="18" FontWeight="SemiBold" />
                    <ComboBox Width="200" HorizontalAlignment="Left" SelectedIndex="0">
                        <ComboBoxItem Content="Option 1" />
                        <ComboBoxItem Content="Option 2" />
                        <ComboBoxItem Content="Option 3" />
                        <ComboBoxItem Content="Option 4" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!--DataGrid Section-->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="DataGrid" FontSize="18" FontWeight="SemiBold" />
                    <DataGrid Name="DemoDataGrid" Width="500" Height="200" HorizontalAlignment="Left"
                              x:DataType="local:DemoItem">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
                            <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="80" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="80" />
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- DatePicker Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="DatePicker" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <DatePicker Width="200" HorizontalAlignment="Left" />
                        <Calendar />
                        <CalendarDatePicker Width="200"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ListBox Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="ListBox" FontSize="18" FontWeight="SemiBold" />
                    <ListBox Width="200" Height="150" HorizontalAlignment="Left" SelectionMode="Single">
                        <ListBoxItem Content="Item One" />
                        <ListBoxItem Content="Item Two" IsSelected="True" />
                        <ListBoxItem Content="Item Three" />
                        <ListBoxItem Content="Item Four" />
                        <ListBoxItem Content="Item Five" />
                        <ListBoxItem Content="Item Six" />
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Menu Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Menu" FontSize="18" FontWeight="SemiBold" />
                    <Menu>
                        <MenuItem Header="File">
                            <MenuItem Header="New" />
                            <MenuItem Header="Open" />
                            <MenuItem Header="Save" />
                            <Separator />
                            <MenuItem Header="Exit" />
                        </MenuItem>
                        <MenuItem Header="Edit">
                            <MenuItem Header="Cut" />
                            <MenuItem Header="Copy" />
                            <MenuItem Header="Paste" />
                        </MenuItem>
                        <MenuItem Header="Help">
                            <MenuItem Header="About" />
                        </MenuItem>
                    </Menu>
                </StackPanel>
            </Border>

            <!-- TabControl Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="TabControl" FontSize="18" FontWeight="SemiBold" />
                    <TabControl Width="400" Height="150" HorizontalAlignment="Left">
                        <TabItem Header="General">
                            <TextBlock Text="General settings content" Margin="8" />
                        </TabItem>
                        <TabItem Header="Advanced">
                            <TextBlock Text="Advanced settings content" Margin="8" />
                        </TabItem>
                        <TabItem Header="About">
                            <TextBlock Text="About this application" Margin="8" />
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </Border>

            <!-- TreeView Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="TreeView" FontSize="18" FontWeight="SemiBold" />
                    <TreeView Width="250" Height="200" HorizontalAlignment="Left">
                        <TreeViewItem Header="Root">
                            <TreeViewItem Header="Child 1">
                                <TreeViewItem Header="Grandchild 1.1" />
                                <TreeViewItem Header="Grandchild 1.2" />
                            </TreeViewItem>
                            <TreeViewItem Header="Child 2" />
                            <TreeViewItem Header="Child 3" IsExpanded="True">
                                <TreeViewItem Header="Grandchild 3.1" />
                                <TreeViewItem Header="Grandchild 3.2" />
                            </TreeViewItem>
                        </TreeViewItem>
                    </TreeView>
                </StackPanel>
            </Border>

            <!-- RepeatButton Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="RepeatButton" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <RepeatButton Content="-" Name="RepeatDecrementBtn" Width="40" Height="40" FontSize="18" />
                        <TextBlock Name="RepeatValueText" Text="0" VerticalAlignment="Center" FontSize="18" Width="40" TextAlignment="Center" />
                        <RepeatButton Content="+" Name="RepeatIncrementBtn" Width="40" Height="40" FontSize="18" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Label & Separator Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Label &amp; Separator" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel>
                        <Label Content="Primary Label" Foreground="{DynamicResource WD.PrimaryBrush}" />
                        <Label Content="Regular label" />
                        <Label Content="HyperlinkButton" Margin="0,8,0,0">
                            <Label.ContentTemplate>
                                <DataTemplate>
                                    <HyperlinkButton Content="{Binding}" NavigateUri="https://github.com/WPFDevelopersOrg/WPFDevelopers.Avalonia" />
                                </DataTemplate>
                            </Label.ContentTemplate>
                        </Label>
                        <Separator Margin="0,12" />
                        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <Label Content="Inline label" />
                            <Border Width="1" Height="16" Background="{DynamicResource WD.BaseBrush}" />
                            <Label Content="After separator" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- NumericUpDown & TimePicker Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="NumericUpDown &amp; TimePicker" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <StackPanel Spacing="4">
                            <Label Content="NumericUpDown" />
                            <NumericUpDown Width="200" HorizontalAlignment="Left" Value="42" Minimum="0" Maximum="1000" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <Label Content="TimePicker" />
                            <TimePicker Width="200" HorizontalAlignment="Left" />
                            <TimePicker Width="200" HorizontalAlignment="Left" UseSeconds="True"/>
                            <TimePicker Width="200" HorizontalAlignment="Left" ClockIdentifier="12HourClock"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- AutoCompleteBox Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="AutoCompleteBox" FontSize="18" FontWeight="SemiBold" />
                    <AutoCompleteBox x:Name="DemoAutoCompleteBox" Width="200" HorizontalAlignment="Left" FilterMode="Contains" Watermark="Search..." />
                </StackPanel>
            </Border>

            <!-- SplitView Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="SplitView" FontSize="18" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <Button Content="Toggle Pane" Name="SplitViewToggleBtn" Theme="{StaticResource wd-primary}" />
                        <RadioButton Content="Compact" GroupName="SplitViewMode" IsChecked="True" Name="SplitViewCompactBtn" />
                        <RadioButton Content="Overlay" GroupName="SplitViewMode" Name="SplitViewOverlayBtn" />
                        <RadioButton Content="Inline" GroupName="SplitViewMode" Name="SplitViewInlineBtn" />
                    </StackPanel>
                    <SplitView x:Name="DemoSplitView" IsPaneOpen="True" OpenPaneLength="200"
                               Width="400" Height="250" HorizontalAlignment="Left"
                               DisplayMode="CompactOverlay">
                        <SplitView.Pane>
                            <StackPanel Background="{DynamicResource WD.BaseMoveBrush}">
                                <TextBlock Text="Pane" FontWeight="SemiBold" Margin="8,0" />
                                <Button Content="Home" Theme="{StaticResource wd-normal}" Margin="0,2" />
                                <Button Content="Settings" Theme="{StaticResource wd-normal}" Margin="0,2" />
                                <Button Content="About" Theme="{StaticResource wd-normal}" Margin="0,2" />
                            </StackPanel>
                        </SplitView.Pane>
                        <Border Background="{DynamicResource WD.LightBrush}" Padding="16">
                            <TextBlock Text="Main Content" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                    </SplitView>
                </StackPanel>
            </Border>

            <!-- ContextMenu Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="ContextMenu" FontSize="18" FontWeight="SemiBold" />
                    <Button Content="Right-click me for ContextMenu" Width="250" HorizontalAlignment="Left" Theme="{StaticResource wd-default}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy" />
                                <MenuItem Header="Paste" />
                                <MenuItem Header="Cut" />
                                <Separator />
                                <MenuItem Header="Select All" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <TextBlock Text="Right-click any control to see its ContextMenu" FontSize="12"
                               Foreground="{DynamicResource WD.RegularTextBrush}" />
                </StackPanel>
            </Border>

            <!-- Toast Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Toast" FontSize="18" FontWeight="SemiBold" />
                    <WrapPanel>
                        <Button Content="Info" Theme="{StaticResource wd-primary}" Margin="4" Name="ToastInfoBtn" />
                        <Button Content="Success" Theme="{StaticResource wd-success}" Margin="4" Name="ToastSuccessBtn" />
                        <Button Content="Warning" Theme="{StaticResource wd-warning}" Margin="4" Name="ToastWarningBtn" />
                        <Button Content="Error" Theme="{StaticResource wd-danger}" Margin="4" Name="ToastErrorBtn" />
                        <Button Content="Clear" Theme="{StaticResource wd-normal}" Margin="4" Name="ToastClearBtn" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- MessageBox Section -->
            <Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="MessageBox" FontSize="18" FontWeight="SemiBold" />
                    <WrapPanel>
                        <Button Content="Info" Theme="{StaticResource wd-primary}" Margin="4" Name="MsgBoxInfoBtn" />
                        <Button Content="Warning" Theme="{StaticResource wd-warning}" Margin="4" Name="MsgBoxWarningBtn" />
                        <Button Content="Error" Theme="{StaticResource wd-danger}" Margin="4" Name="MsgBoxErrorBtn" />
                        <Button Content="Question" Theme="{StaticResource wd-success}" Margin="4" Name="MsgBoxQuestionBtn" />
                        <Button Content="YesNoCancel" Theme="{StaticResource wd-default}" Margin="4" Name="MsgBoxYesNoCancelBtn" />
                    </WrapPanel>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</Window>
