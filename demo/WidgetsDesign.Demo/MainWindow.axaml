<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:controls="using:WidgetsDesign.Avalonia.Controls"
		mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
		x:Class="WidgetsDesign.Demo.MainWindow"
		Title="WidgetsDesign Demo"
		Width="800" Height="600">

	<ScrollViewer Padding="20">
		<StackPanel Spacing="20">
			<!-- Title -->
			<TextBlock Text="WidgetsDesign.Avalonia Demo"
					   FontSize="24" FontWeight="Bold"
					   HorizontalAlignment="Center" />

			<!-- Theme Toggle -->
			<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
				<TextBlock Text="Theme:" VerticalAlignment="Center" />
				<Button Name="ThemeToggle" Content="Switch to Dark" Classes="wd-primary" />
			</StackPanel>

			<!-- Buttons Section -->
			<Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="Buttons" FontSize="18" FontWeight="SemiBold" />
					<WrapPanel>
						<Button Content="Primary" Classes="wd-primary" Margin="4" />
						<Button Content="Default" Classes="wd-default" Margin="4" />
						<Button Content="Normal" Classes="wd-normal" Margin="4" />
						<Button Content="Success" Classes="wd-success" Margin="4" />
						<Button Content="Warning" Classes="wd-warning" Margin="4" />
						<Button Content="Danger" Classes="wd-danger" Margin="4" />
						<Button Content="Filled Success" Classes="wd-success-filled" Margin="4" />
						<Button Content="Filled Warning" Classes="wd-warning-filled" Margin="4" />
						<Button Content="Filled Danger" Classes="wd-danger-filled" Margin="4" />
					</WrapPanel>
				</StackPanel>
			</Border>

			<!-- PathIcon Section -->
			<Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="Icons" FontSize="18" FontWeight="SemiBold" />
					<WrapPanel>
						<controls:PathIcon Kind="Home" Width="24" Height="24" Foreground="{DynamicResource WD.PrimaryBrush}" Margin="4" />
						<controls:PathIcon Kind="CheckMark" Width="24" Height="24" Foreground="{DynamicResource WD.SuccessBrush}" Margin="4" />
						<controls:PathIcon Kind="Warning" Width="24" Height="24" Foreground="{DynamicResource WD.WarningBrush}" Margin="4" />
						<controls:PathIcon Kind="Error" Width="24" Height="24" Foreground="{DynamicResource WD.DangerBrush}" Margin="4" />
						<controls:PathIcon Kind="Info" Width="24" Height="24" Foreground="{DynamicResource WD.PrimaryBrush}" Margin="4" />
						<controls:PathIcon Kind="Star" Width="24" Height="24" Foreground="{DynamicResource WD.WarningBrush}" Margin="4" />
						<controls:PathIcon Kind="Add" Width="24" Height="24" Foreground="{DynamicResource WD.PrimaryBrush}" Margin="4" />
						<controls:PathIcon Kind="Time" Width="24" Height="24" Foreground="{DynamicResource WD.RegularTextBrush}" Margin="4" />
						<controls:PathIcon Kind="Date" Width="24" Height="24" Foreground="{DynamicResource WD.RegularTextBrush}" Margin="4" />
						<controls:PathIcon Kind="Copy" Width="24" Height="24" Foreground="{DynamicResource WD.RegularTextBrush}" Margin="4" />
						<controls:PathIcon Kind="Undo" Width="24" Height="24" Foreground="{DynamicResource WD.RegularTextBrush}" Margin="4" />
						<controls:PathIcon Kind="Filter" Width="24" Height="24" Foreground="{DynamicResource WD.RegularTextBrush}" Margin="4" />
					</WrapPanel>
				</StackPanel>
			</Border>

			<!-- Inputs Section -->
			<Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="Inputs" FontSize="18" FontWeight="SemiBold" />
					<TextBox Text="" Watermark="Enter text here..." Width="200" MaxWidth="400" HorizontalAlignment="Left" />
					<StackPanel Orientation="Horizontal" Spacing="16">
						<TextBox PasswordChar="*" Watermark="Enter password here..." Width="200" MaxWidth="400" HorizontalAlignment="Left"/>
						<TextBox PasswordChar="*" Watermark="Enter password here..." Width="200" RevealPassword="True" MaxWidth="400" HorizontalAlignment="Left"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="16">
						<CheckBox Content="CheckBox (checked)" IsChecked="True" />
						<CheckBox Content="CheckBox (unchecked)" />
						<CheckBox Content="CheckBox (indeterminate)" IsThreeState="True" IsChecked="{x:Null}" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="16">
						<RadioButton Content="Option A" GroupName="demo" IsChecked="True" />
						<RadioButton Content="Option B" GroupName="demo" />
						<RadioButton Content="Option C" GroupName="demo" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Spacing="16">
						<ToggleButton Content="Toggle Off" />
						<ToggleButton Content="Toggle On" IsChecked="True" />
						<ToggleButton Classes="wd-switch" IsChecked="True" />
						<ToggleButton Classes="wd-switch" />
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- Tag Section -->
			<Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="Tags" FontSize="18" FontWeight="SemiBold" />
					<WrapPanel>
						<controls:Tag Content="Default Tag" Margin="4" Close="Tag_Close" />
						<controls:Tag Content="Non-closable" IsClose="False" Margin="4" />
					</WrapPanel>
				</StackPanel>
			</Border>

			<!-- Loading Section -->
			<Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="Loading Indicators" FontSize="18" FontWeight="SemiBold" />
					<!--<StackPanel Orientation="Horizontal" Spacing="32">
						<StackPanel HorizontalAlignment="Center">
							<controls:NormalLoading IsLoading="True" />
							<TextBlock Text="Normal" HorizontalAlignment="Center" Margin="0,8,0,0" />
						</StackPanel>
						<StackPanel HorizontalAlignment="Center">
							<controls:BallLoading IsLoading="True" />
							<TextBlock Text="Ball" HorizontalAlignment="Center" Margin="0,8,0,0" />
						</StackPanel>
					</StackPanel>-->
				</StackPanel>
			</Border>

			<!-- Badge Section -->
			<Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="Badge" FontSize="18" FontWeight="SemiBold" />
					<WrapPanel>
						<controls:BadgeControl Text="5" Margin="16">
							<Button Content="Messages" Classes="wd-default" />
						</controls:BadgeControl>
						<controls:BadgeControl Text="99+" Margin="16">
							<Button Content="Notifications" Classes="wd-default" />
						</controls:BadgeControl>
						<controls:BadgeControl IsDot="True" Margin="16">
							<Button Content="Dot Badge" Classes="wd-default" />
						</controls:BadgeControl>
					</WrapPanel>
				</StackPanel>
			</Border>

			<!-- Progress Section -->
			<Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="Progress &amp; Slider" FontSize="18" FontWeight="SemiBold" />
					<ProgressBar Value="60" Width="400" HorizontalAlignment="Left" />
					<Slider Width="400" HorizontalAlignment="Left" Minimum="0" Maximum="100" Value="40" />
				</StackPanel>
			</Border>

			<!-- Expander Section -->
			<Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="Expander" FontSize="18" FontWeight="SemiBold" />
					<Expander Header="Click to expand" Width="400" HorizontalAlignment="Left">
						<TextBlock Text="This is the expanded content. You can put anything here."
								   TextWrapping="Wrap" Padding="8" />
					</Expander>
				</StackPanel>
			</Border>

			<!-- ComboBox Section -->
			<Border BorderBrush="{DynamicResource WD.BaseBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
				<StackPanel Spacing="12">
					<TextBlock Text="ComboBox" FontSize="18" FontWeight="SemiBold" />
					<ComboBox Width="200" HorizontalAlignment="Left" SelectedIndex="0">
						<ComboBoxItem Content="Option 1" />
						<ComboBoxItem Content="Option 2" />
						<ComboBoxItem Content="Option 3" />
						<ComboBoxItem Content="Option 4" />
					</ComboBox>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</Window>
