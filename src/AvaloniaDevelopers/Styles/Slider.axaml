<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Slider Style -->
    <Style Selector="Slider">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Name="grid">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" MinHeight="20" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TickBar Name="TopTick" Grid.Row="0"
                             Placement="Top" Height="4"
                             Fill="{DynamicResource WD.RegularTextBrush}"
                             IsVisible="False" />
                    <TickBar Name="BottomTick" Grid.Row="2"
                             Placement="Bottom" Height="4"
                             Fill="{DynamicResource WD.RegularTextBrush}"
                             IsVisible="False" />
                    <Border Name="TrackBackground" Grid.Row="1"
                            Height="4" VerticalAlignment="Center"
                            Background="{DynamicResource WD.BaseBrush}"
                            CornerRadius="2" />
                    <Track Name="PART_Track" Grid.Row="1"
                           IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                        <Track.DecreaseButton>
                            <RepeatButton Name="PART_DecreaseButton" />
                        </Track.DecreaseButton>
                        <Track.IncreaseButton>
                            <RepeatButton Name="PART_IncreaseButton" />
                        </Track.IncreaseButton>
                        <Track.Thumb>
                            <Thumb Name="thumb"
                                   Width="16" Height="16"
                                   Background="{DynamicResource WD.PrimaryBrush}"
                                   CornerRadius="8" />
                        </Track.Thumb>
                    </Track>
                </Grid>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:vertical /template/ Grid#grid">
            <Setter Property="Margin" Value="10,0" />
        </Style>
        <Style Selector="^ /template/ Thumb#thumb:pointerover">
            <Setter Property="Background" Value="{DynamicResource WD.PrimaryBrush}" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <Style Selector="^:disabled">
            <Setter Property="Opacity" Value="{DynamicResource WD.EnabledOpacity}" />
        </Style>
    </Style>

    <!-- Decrease button fill -->
    <Style Selector="Slider /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{DynamicResource WD.PrimaryBrush}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" CornerRadius="2" />
            </ControlTemplate>
        </Setter>
    </Style>

</Styles>
