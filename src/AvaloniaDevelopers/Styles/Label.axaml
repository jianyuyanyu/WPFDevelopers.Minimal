<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Label Style -->
    <Style Selector="Label">
        <Setter Property="Foreground" Value="{DynamicResource WD.PrimaryTextBrush}" />
        <Setter Property="FontSize" Value="{DynamicResource WD.PrimaryFontSize}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- HyperlinkButton Style -->
    <Style Selector="HyperlinkButton">
        <Setter Property="Foreground" Value="{DynamicResource WD.PrimaryBrush}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="HyperlinkButton:pointerover">
        <Setter Property="Opacity" Value="0.8" />
    </Style>

</Styles>
