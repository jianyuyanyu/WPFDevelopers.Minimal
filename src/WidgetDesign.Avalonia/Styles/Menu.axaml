<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Menu Style -->
    <ControlTheme x:Key="{x:Type Menu}" TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource WD.BackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource WD.PrimaryTextBrush}" />
    </ControlTheme>

    <!-- MenuItem Style -->
    <ControlTheme x:Key="{x:Type MenuItem}" TargetType="MenuItem">
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="border"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}"
                        CornerRadius="4">
                    <DockPanel>
                        <Path Name="icon"
                              DockPanel.Dock="Left"
                              Width="12" Height="12"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center"
                              Fill="{DynamicResource WD.RegularTextBrush}"
                              Data="{StaticResource WD.ChevronRightGeometry}" />
                        <ContentPresenter Name="PART_Header"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}" />
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover">
            <Style Selector="^ /template/ Border#border">
                <Setter Property="Background" Value="{DynamicResource WD.PrimaryMouseOverBrush}" />
            </Style>
        </Style>
    </ControlTheme>

    <!-- ContextMenu Style -->
    <ControlTheme x:Key="{x:Type ContextMenu}" TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource WD.BackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource WD.BaseBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="CornerRadius" Value="{DynamicResource WD.CornerRadius}" />
    </ControlTheme>

</ResourceDictionary>
