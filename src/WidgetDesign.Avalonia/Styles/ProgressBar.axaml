<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ControlTheme x:Key="{x:Type ProgressBar}" TargetType="ProgressBar">
        <Setter Property="Height" Value="8" />
        <Setter Property="Width" Value="150" />
        <Setter Property="Background" Value="{DynamicResource WD.BaseBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource WD.PrimaryBrush}" />
        <Setter Property="CornerRadius" Value="{DynamicResource WD.CornerRadius}" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid x:Name="PART_HorizontalRoot"
                      ColumnDefinitions="Auto, *, Auto">
                    <Border Name="PART_Track"
                            Grid.Column="1"
                            Height="4"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <Panel>
                            <Panel x:Name="DeterminateRoot" Opacity="1">
                                <Panel.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                                    </Transitions>
                                </Panel.Transitions>
                                <Border Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="{TemplateBinding CornerRadius}">
                                    <Border.Transitions>
                                        <Transitions>
                                            <DoubleTransition Easing="CircularEaseOut"
                                                              Property="Width"
                                                              Duration="0:0:0.5" />
                                            <BrushTransition Property="Background" Duration="0:0:0.3" />
                                        </Transitions>
                                    </Border.Transitions>
                                </Border>
                            </Panel>
                            <Panel x:Name="IndeterminateRoot" Opacity="0">
                                <Panel.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                                    </Transitions>
                                </Panel.Transitions>
                                <Border x:Name="IndeterminateBar1"
                                        Margin="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="{TemplateBinding CornerRadius}">
                                    <Border.RenderTransform>
                                        <TranslateTransform />
                                    </Border.RenderTransform>
                                </Border>
                                <Border x:Name="IndeterminateBar2"
                                        Margin="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="{TemplateBinding CornerRadius}">
                                    <Border.RenderTransform>
                                        <TranslateTransform />
                                    </Border.RenderTransform>
                                </Border>
                            </Panel>
                        </Panel>
                    </Border>
                    <TextBlock Name="PART_Text"
                               Width="0"
                               Height="0"
                               Grid.Column="2"
                               Foreground="{DynamicResource WD.RegularTextColor}"
                               FontSize="10"
                               IsVisible="{TemplateBinding ShowProgressText}"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0">
                        <TextBlock.Text>
                            <MultiBinding Converter="{StaticResource StringFormatConverter}">
                                <TemplateBinding Property="ProgressTextFormat" />
                                <TemplateBinding Property="Value" />
                                <TemplateBinding Property="Percentage" />
                                <TemplateBinding Property="Minimum" />
                                <TemplateBinding Property="Maximum" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:horizontal[ShowProgressText=True] /template/ TextBlock#PART_Text">
            <Setter Property="Height" Value="NaN" />
            <Style.Animations>
                <Animation FillMode="Forward" Duration="0:0:0.35">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="Width" Value="0" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.35">
                        <Setter Property="Width" Value="35" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="^:horizontal[ShowProgressText=False] /template/ TextBlock#PART_Text">
            <Style.Animations>
                <Animation FillMode="Forward" Duration="0:0:0.35">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="Width" Value="35" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.35">
                        <Setter Property="Width" Value="0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="^:vertical[ShowProgressText=True] /template/ TextBlock#PART_Text">
            <Setter Property="Width" Value="NaN" />
            <Setter Property="Height" Value="NaN" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style Selector="^:indeterminate /template/ Panel#DeterminateRoot">
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="^:indeterminate /template/ Panel#IndeterminateRoot">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="^:horizontal /template/ Border#IndeterminateBar1">
            <Setter Property="Width" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerWidth}" />
        </Style>
        <Style Selector="^:horizontal /template/ Border#IndeterminateBar2">
            <Setter Property="Width" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2Width}" />
        </Style>

        <Style Selector="^:vertical /template/ Border#IndeterminateBar1">
            <Setter Property="Height" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerWidth}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="^:vertical /template/ Border#IndeterminateBar2">
            <Setter Property="Height" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2Width}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="^:vertical /template/ Border#PART_Indicator">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Width" Value="NaN" />
        </Style>

        <Style Selector="^:horizontal:indeterminate /template/ Border#IndeterminateBar1">
            <Style.Animations>
                <Animation IterationCount="Infinite" Duration="0:0:2">
                    <KeyFrame KeyTime="0:0:0" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerAnimationStartPosition}" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1.5" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerAnimationEndPosition}" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:2" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerAnimationEndPosition}" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="^:horizontal:indeterminate /template/ Border#IndeterminateBar2">
            <Style.Animations>
                <Animation IterationCount="Infinite" Duration="0:0:2">
                    <KeyFrame KeyTime="0:0:0" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2AnimationStartPosition}" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.75" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2AnimationStartPosition}" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:2" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.X" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2AnimationEndPosition}" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="^:vertical:indeterminate /template/ Border#IndeterminateBar1">
            <Style.Animations>
                <Animation IterationCount="Infinite" Duration="0:0:2">
                    <KeyFrame KeyTime="0:0:0" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.Y" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerAnimationStartPosition}" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1.5" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.Y" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerAnimationEndPosition}" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:2" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.Y" Value="{Binding $parent[ProgressBar].TemplateSettings.ContainerAnimationEndPosition}" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="^:vertical:indeterminate /template/ Border#IndeterminateBar2">
            <Style.Animations>
                <Animation IterationCount="Infinite" Duration="0:0:2">
                    <KeyFrame KeyTime="0:0:0" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.Y" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2AnimationStartPosition}" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.75" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.Y" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2AnimationStartPosition}" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:2" KeySpline="0.4,0,0.6,1">
                        <Setter Property="TranslateTransform.Y" Value="{Binding $parent[ProgressBar].TemplateSettings.Container2AnimationEndPosition}" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="^:vertical">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="150" />
        </Style>
        <Style Selector="^:vertical /template/ Border#PART_Track">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Height" Value="NaN" />
        </Style>
        <Style Selector="^:vertical /template/ TextBlock#PART_Text">
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </ControlTheme>

</ResourceDictionary>
