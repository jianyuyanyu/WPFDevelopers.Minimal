<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Calendar Style -->
    <ControlTheme x:Key="{x:Type Calendar}" TargetType="Calendar">
        <Setter Property="Background" Value="{DynamicResource WD.BackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource WD.BaseBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource WD.CornerRadius}" />
        <Setter Property="DisplayDateStart" Value="1900-01-01" />
        <Setter Property="DisplayDateEnd" Value="2100-12-31" />
        <Setter Property="Template">
            <ControlTemplate TargetType="Calendar">
                <StackPanel Name="PART_Root"
                            HorizontalAlignment="Center"
                            ClipToBounds="True">
                    <CalendarItem Name="PART_CalendarItem"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  CornerRadius="{TemplateBinding CornerRadius}" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <!-- CalendarItem Style -->
    <ControlTheme x:Key="{x:Type CalendarItem}" TargetType="CalendarItem">
        <Setter Property="MinWidth" Value="280" />
        <Setter Property="MinHeight" Value="280" />
        <Setter Property="Template">
            <ControlTemplate TargetType="CalendarItem">
                <Border Padding="16"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Grid MinWidth="{TemplateBinding MinWidth}"
                          MinHeight="{TemplateBinding MinHeight}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          RowDefinitions="Auto,*">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                            <RepeatButton Name="PART_PreviousButton"
                                          Grid.Column="0"
                                          Padding="0"
                                          MinWidth="{Binding $self.MinHeight}">
                                <PathIcon Data="{StaticResource WD.PreviousGeometry}" />
                            </RepeatButton>
                            <Button Name="PART_HeaderButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" />
                            <RepeatButton Name="PART_NextButton"
                                          Grid.Column="2"
                                          Padding="0"
                                          MinWidth="{Binding $self.MinHeight}">
                                <PathIcon Data="{StaticResource WD.NextGeometry}" />
                            </RepeatButton>
                        </Grid>
                        <Grid Name="PART_MonthView"
                              Grid.Row="1"
                              HorizontalAlignment="Stretch"
                              IsVisible="False"
                              ColumnDefinitions="*,*,*,*,*,*,*">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <CalendarDayButton Grid.Row="1" Grid.Column="0" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="1" Grid.Column="1" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="1" Grid.Column="2" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="1" Grid.Column="3" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="1" Grid.Column="4" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="1" Grid.Column="5" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="1" Grid.Column="6" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="2" Grid.Column="0" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="2" Grid.Column="1" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="2" Grid.Column="2" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="2" Grid.Column="3" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="2" Grid.Column="4" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="2" Grid.Column="5" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="2" Grid.Column="6" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="3" Grid.Column="0" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="3" Grid.Column="1" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="3" Grid.Column="2" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="3" Grid.Column="3" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="3" Grid.Column="4" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="3" Grid.Column="5" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="3" Grid.Column="6" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="4" Grid.Column="0" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="4" Grid.Column="1" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="4" Grid.Column="2" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="4" Grid.Column="3" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="4" Grid.Column="4" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="4" Grid.Column="5" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="4" Grid.Column="6" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="5" Grid.Column="0" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="5" Grid.Column="1" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="5" Grid.Column="2" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="5" Grid.Column="3" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="5" Grid.Column="4" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="5" Grid.Column="5" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="5" Grid.Column="6" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="6" Grid.Column="0" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="6" Grid.Column="1" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="6" Grid.Column="2" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="6" Grid.Column="3" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="6" Grid.Column="4" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="6" Grid.Column="5" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                            <CalendarDayButton Grid.Row="6" Grid.Column="6" Theme="{StaticResource {x:Type CalendarDayButton}}" />
                        </Grid>
                        <Grid Name="PART_YearView"
                              Grid.Row="1"
                              Background="{TemplateBinding Background}"
                              IsVisible="False"
                              ColumnDefinitions="*,*,*,*"
                              RowDefinitions="*,*,*">
                            <CalendarButton Grid.Row="0" Grid.Column="0" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="0" Grid.Column="1" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="0" Grid.Column="2" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="0" Grid.Column="3" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="1" Grid.Column="0" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="1" Grid.Column="1" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="1" Grid.Column="2" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="1" Grid.Column="3" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="2" Grid.Column="0" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="2" Grid.Column="1" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="2" Grid.Column="2" Theme="{StaticResource {x:Type CalendarButton}}" />
                            <CalendarButton Grid.Row="2" Grid.Column="3" Theme="{StaticResource {x:Type CalendarButton}}" />
                        </Grid>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

    <!-- CalendarButton Style -->
    <ControlTheme x:Key="{x:Type CalendarButton}" TargetType="CalendarButton">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate TargetType="CalendarButton">
                <ContentControl Name="Content"
                                Padding="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                FontSize="{TemplateBinding FontSize}" />
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover /template/ ContentControl#Content">
            <Setter Property="Background" Value="{DynamicResource WD.BaseMoveBrush}" />
        </Style>
        <Style Selector="^:today /template/ ContentControl#Content">
            <Setter Property="BorderBrush" Value="{DynamicResource WD.PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="^:selected /template/ ContentControl#Content">
            <Setter Property="Background" Value="{DynamicResource WD.PrimaryBrush}" />
        </Style>
        <Style Selector="^:inactive /template/ ContentControl#Content">
            <Setter Property="Opacity" Value="0.4" />
        </Style>
    </ControlTheme>

    <!-- CalendarDayButton Style -->
    <ControlTheme x:Key="{x:Type CalendarDayButton}" TargetType="CalendarDayButton">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Margin" Value="2" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <ControlTemplate TargetType="CalendarDayButton">
                <ContentControl Name="Content"
                                Padding="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                FontSize="{TemplateBinding FontSize}" />
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover /template/ ContentControl#Content">
            <Setter Property="Background" Value="{DynamicResource WD.BaseMoveBrush}" />
        </Style>
        <Style Selector="^:today /template/ ContentControl#Content">
            <Setter Property="Background" Value="{DynamicResource WD.PrimaryBrush}" />
        </Style>
        <Style Selector="^:selected /template/ ContentControl#Content">
            <Setter Property="Background" Value="{DynamicResource WD.PrimaryBrush}" />
        </Style>
        <Style Selector="^:inactive /template/ ContentControl#Content">
            <Setter Property="Foreground" Value="{DynamicResource WD.SecondaryTextBrush}" />
        </Style>
    </ControlTheme>

</ResourceDictionary>
