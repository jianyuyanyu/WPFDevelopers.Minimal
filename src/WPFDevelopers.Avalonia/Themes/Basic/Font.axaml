<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="using:System">

    
    <x:Double x:Key="WD.PrimaryFontSize">13</x:Double>
    <x:Double x:Key="WD.MediumFontSize">14</x:Double>
    <x:Double x:Key="WD.TitleFontSize">16</x:Double>

    
    <FontFamily x:Key="WD.FontFamily">avares://WPFDevelopers.Avalonia/Themes/Basic#Helvetica Neue,Segoe UI,Roboto,PingFang SC,Microsoft YaHei,sans-serif</FontFamily>
    <FontStyle x:Key="WD.FontStyle">Normal</FontStyle>
    <FontWeight x:Key="WD.FontWeight">Normal</FontWeight>
    <FontStretch x:Key="WD.FontStretch">Normal</FontStretch>

</ResourceDictionary>
