<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ScrollBar Style -->
    <Style Selector="ScrollBar">
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Horizontal ScrollBar -->
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="14" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_Border"
                        Background="Transparent"
                        UseLayoutRounding="False">
                    <Track Name="PART_Track"
                           Orientation="Horizontal"
                           Minimum="{TemplateBinding Minimum}"
                           Maximum="{TemplateBinding Maximum}"
                           ViewportSize="{TemplateBinding ViewportSize}"
                           Value="{TemplateBinding Value, Mode=TwoWay}">
                        <Track.DecreaseButton>
                            <RepeatButton Name="PART_LineUpButton"
                                          Focusable="False"
                                          Background="Transparent" />
                        </Track.DecreaseButton>
                        <Track.IncreaseButton>
                            <RepeatButton Name="PART_LineDownButton"
                                          Focusable="False"
                                          Background="Transparent" />
                        </Track.IncreaseButton>
                        <Thumb Name="PART_Thumb">
                            <Thumb.Template>
                                <ControlTemplate>
                                    <Border Name="thumbBorder"
                                            Background="{DynamicResource WD.RegularTextBrush}"
                                            CornerRadius="7"
                                            UseLayoutRounding="False" />
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Vertical ScrollBar -->
    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="14" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_Border"
                        Background="Transparent"
                        UseLayoutRounding="False">
                    <Track Name="PART_Track"
                           Orientation="Vertical"
                           IsDirectionReversed="True"
                           Minimum="{TemplateBinding Minimum}"
                           Maximum="{TemplateBinding Maximum}"
                           ViewportSize="{TemplateBinding ViewportSize}"
                           Value="{TemplateBinding Value, Mode=TwoWay}">
                        <Track.DecreaseButton>
                            <RepeatButton Name="PART_LineUpButton"
                                          Focusable="False"
                                          Background="Transparent" />
                        </Track.DecreaseButton>
                        <Track.IncreaseButton>
                            <RepeatButton Name="PART_LineDownButton"
                                          Focusable="False"
                                          Background="Transparent" />
                        </Track.IncreaseButton>
                        <Thumb Name="PART_Thumb">
                            <Thumb.Template>
                                <ControlTemplate>
                                    <Border Name="thumbBorder"
                                            Background="{DynamicResource WD.RegularTextBrush}"
                                            CornerRadius="7"
                                            UseLayoutRounding="False" />
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Thumb: horizontal size -->
    <Style Selector="ScrollBar:horizontal /template/ Thumb#PART_Thumb">
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="Height" Value="10" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Thumb: vertical size -->
    <Style Selector="ScrollBar:vertical /template/ Thumb#PART_Thumb">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Width" Value="10" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Thumb: horizontal hover -->
    <Style Selector="ScrollBar:horizontal /template/ Thumb#PART_Thumb:pointerover /template/ Border#thumbBorder">
        <Setter Property="Background" Value="{DynamicResource WD.PrimaryTextBrush}" />
    </Style>

    <!-- Thumb: vertical hover -->
    <Style Selector="ScrollBar:vertical /template/ Thumb#PART_Thumb:pointerover /template/ Border#thumbBorder">
        <Setter Property="Background" Value="{DynamicResource WD.PrimaryTextBrush}" />
    </Style>

    <!-- ScrollViewer Style -->
    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="*,Auto">
                    <ScrollContentPresenter Name="PART_ContentPresenter"
                                            Grid.RowSpan="2"
                                            Grid.ColumnSpan="2"
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            HorizontalSnapPointsAlignment="{TemplateBinding HorizontalSnapPointsAlignment}"
                                            HorizontalSnapPointsType="{TemplateBinding HorizontalSnapPointsType}"
                                            VerticalSnapPointsAlignment="{TemplateBinding VerticalSnapPointsAlignment}"
                                            VerticalSnapPointsType="{TemplateBinding VerticalSnapPointsType}">
                        <ScrollContentPresenter.GestureRecognizers>
                            <ScrollGestureRecognizer CanHorizontallyScroll="{Binding CanHorizontallyScroll, ElementName=PART_ContentPresenter}"
                                                     CanVerticallyScroll="{Binding CanVerticallyScroll, ElementName=PART_ContentPresenter}" />
                        </ScrollContentPresenter.GestureRecognizers>
                    </ScrollContentPresenter>
                    <ScrollBar Name="PART_HorizontalScrollBar"
                               Grid.Row="1"
                               Grid.Column="0"
                               Orientation="Horizontal" />
                    <ScrollBar Name="PART_VerticalScrollBar"
                               Grid.Row="0"
                               Grid.Column="1"
                               Orientation="Vertical" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

</Styles>
