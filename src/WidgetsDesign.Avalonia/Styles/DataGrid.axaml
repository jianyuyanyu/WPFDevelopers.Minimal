<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dg="using:Avalonia.Controls">

    <!-- DataGrid Style -->
    <Style Selector="dg|DataGrid">
        <Setter Property="Background" Value="{DynamicResource WD.BackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource WD.BaseBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource WD.LighterBrush}" />
        <Setter Property="CornerRadius" Value="{DynamicResource WD.CornerRadius}" />
    </Style>

    <!-- DataGridColumnHeader Style -->
    <Style Selector="dg|DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource WD.BaseMoveBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource WD.PrimaryTextBrush}" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="BorderBrush" Value="{DynamicResource WD.LightBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

    <!-- DataGridRow Style -->
    <Style Selector="dg|DataGridRow">
        <Setter Property="Background" Value="{DynamicResource WD.BackgroundBrush}" />
    </Style>
    <Style Selector="dg|DataGridRow:pointerover">
        <Setter Property="Background" Value="{DynamicResource WD.BaseMoveBrush}" />
    </Style>
    <Style Selector="dg|DataGridRow:selected">
        <Setter Property="Background" Value="{DynamicResource WD.PrimaryMouseOverBrush}" />
    </Style>

    <!-- DataGridCell Style -->
    <Style Selector="dg|DataGridCell">
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="BorderBrush" Value="{DynamicResource WD.LightBrush}" />
    </Style>

</Styles>
